{
  "name": "@chathtml/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n client,server -c cyan,green \"vite --host 127.0.0.1\" \"tsx watch server/index.ts\"",
    "server": "tsx server/index.ts",
    "build": "tsc -p tsconfig.app.json && tsc -p tsconfig.node.json --noEmit && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "test": "tsx --test src/**/*.test.ts"
  },
  "dependencies": {
    "@assistant-ui/react": "^0.14.24",
    "@openrouter/ai-sdk-provider": "^2.10.0",
    "@vitejs/plugin-react": "^4.3.4",
    "ai": "^6.0.218",
    "cheerio": "1.0.0",
    "dom-to-svg": "^0.12.2",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "lucide-react": "^1.23.0",
    "playwright": "^1.61.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sqlite": "^5.1.1",
    "sqlite3": "^5.1.7",
    "zod": "^4.1.8"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "concurrently": "^9.1.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^6.0.6"
  }
}
