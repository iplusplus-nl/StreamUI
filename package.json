{
  "name": "chathtml",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=18.19.0"
  },
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "npm --workspace @chathtml/web run dev",
    "server": "npm --workspace @chathtml/web run server",
    "build": "npm --workspace @chathtml/web run build",
    "preview": "npm --workspace @chathtml/web run preview",
    "test": "npm --workspace @chathtml/web run test",
    "ai:fix-issue": "node scripts/codex-fix-issue.mjs",
    "wait:deploy-idle": "node scripts/wait-for-deploy-idle.mjs"
  }
}
