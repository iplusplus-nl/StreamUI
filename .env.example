OPENROUTER_API_KEY=your_openrouter_key_here
OPENROUTER_MODEL=google/gemini-3.5-flash
OPENROUTER_REASONING_EFFORT=low

# Server-only local override. Production defaults to the fixed
# https://service.aietheia.com/v1 endpoint in server/chatHtmlService.ts.
CHATHTML_SERVICE_BASE_URL=http://127.0.0.1:8790/v1
CHATHTML_PUBLIC_ORIGIN=http://127.0.0.1:5173
CHATHTML_APP_OAUTH_REDIRECT_URI=chathtml://oauth/callback

# Production requires a valid account by default. Set this explicitly when a
# non-production environment should exercise the same account gate.
CHATHTML_AUTH_REQUIRED=
# Comma-separated immutable account IDs allowed to use admin-only ChatHTML APIs.
# Service-side `admin` roles not listed here are treated as normal users.
CHATHTML_ADMIN_USER_IDS=

# PostgreSQL is recommended for hosted deployments. It stores one atomic state
# row per authenticated user and permits different users to save concurrently.
# Keep credentials server-side and require TLS when the database is remote.
CHATHTML_DATABASE_URL=
CHATHTML_DATABASE_POOL_SIZE=10

# SQLite remains the zero-setup local-development backend when no PostgreSQL
# URL is configured. Point it at persistent storage if used beyond local dev.
STREAMUI_SESSION_DB=./sessions/state.sqlite

# ChatHTML runs retrieval locally before final HTML generation.
STREAMUI_RETRIEVAL=true
STREAMUI_SEARCH_PROVIDER=auto
STREAMUI_SEARCH_MAX_RESULTS=5
STREAMUI_SEARCH_ALLOW_DUCKDUCKGO=true
STREAMUI_RETRIEVAL_MAX_PAGES=4
STREAMUI_PAGE_MAX_CHARS=10000
STREAMUI_RETRIEVAL_CONTEXT_MAX_CHARS=32000
STREAMUI_RETRIEVAL_TIMEOUT_MS=12000
STREAMUI_BROWSER_ENGINE=fetch

# Optional comma-separated domain controls for retrieval.
STREAMUI_RETRIEVAL_ALLOWED_DOMAINS=
STREAMUI_RETRIEVAL_BLOCKED_DOMAINS=
STREAMUI_RETRIEVAL_ALLOW_PRIVATE_URLS=false

# Optional search API providers. With STREAMUI_SEARCH_PROVIDER=auto,
# ChatHTML tries configured API providers before DuckDuckGo fallback.
BRAVE_SEARCH_API_KEY=
TAVILY_API_KEY=
SERPER_API_KEY=

# Optional visual-source APIs. Openverse, NASA, Library of Congress, The Met,
# and Art Institute of Chicago run without keys. These keys enable additional
# photo/museum sources during image/gallery retrieval.
PEXELS_API_KEY=
UNSPLASH_ACCESS_KEY=
RIJKSMUSEUM_API_KEY=

# Optional GitHub issue sync for in-app bug reports.
# Keep token values only in local/production .env files, never in git.
GITHUB_REPOSITORY=aietheia/ChatHTML
GITHUB_ISSUES_TOKEN=
GITHUB_ISSUE_LABELS=bug,user-report
GITHUB_ISSUE_ASSIGNEES=
CHATHTML_BUG_REPORT_ISSUE_BASE_URL=http://127.0.0.1:8787
CHATHTML_BUG_REPORT_IMAGE_ALLOW_PUBLIC=false
# GitHub issue synchronization is off unless explicitly enabled. Use only a
# private repository for user-submitted reports.
CHATHTML_GITHUB_ISSUE_SYNC_ENABLED=false
CHATHTML_API_RATE_LIMIT_PER_MINUTE=300
CHATHTML_ACCOUNT_CONCURRENT_REQUESTS=8
CHATHTML_MAX_ACCOUNT_SESSIONS=200
CHATHTML_MAX_ACCOUNT_MESSAGES=5000
CHATHTML_MAX_ACCOUNT_FILES=200
CHATHTML_MAX_ACCOUNT_FILE_BYTES=104857600
CHATHTML_BUG_REPORT_RETENTION_DAYS=30
